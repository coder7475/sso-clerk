# Clerk Authentication Environment Variables
#
# Copy this file to .env.local and fill in your Clerk keys.
# Get your keys from: https://clerk.com/docs/quickstarts/setup-clerk
#
# For local development, you'll need to create a Clerk application
# at https://clerk.com and copy the publishable key below.

# Required: Your Clerk Publishable Key
# Format: pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=test_your_publishable_key_here

# Required: Your Clerk Secret Key
# Your Clerk Secret Key
CLERK_SECRET_KEY=your_secret_key_here

# Optional: Clerk URLs (required for production)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Optional: Domain configuration (for multi-domain setups)
# NEXT_PUBLIC_CLERK_DOMAIN=your-domain.com
# NEXT_PUBLIC_CLERK_PROXY_URL=https://your-proxy-url.com/ClerkProxyServer

# Optional: Development mode warning suppression (not recommended for production)
# NEXT_PUBLIC_CLERK_UNSAFE_DISABLE_DEVELOPMENT_MODE_CONSOLE_WARNING=true
